{
    "name": "NN_vector_resnet",
    "n_gpu": 1,

    "arch": {
        "type": "model_NN_vector_resnet",
        "args": {}
    },
    "data_loader": {
        "type": "CICIoV2024_DataLoader",
        "args": {
            "data_dir": "data/CICIoV2024_split",
            "batch_size": 128,
            "shuffle": true,
            "num_workers": 2
        }
    },
    "optimizer": {
        "type": "AdamW",
        "args": {
            "lr": 0.001,
            "weight_decay": 0.0001,
            "amsgrad": true
        }
    },
    "loss": "nll_loss",
    "metrics": [
        "accuracy",
        "top_k_acc"
    ],
    "lr_scheduler": {
        "type": "CosineAnnealingLR",
        "args": {
            "T_max": 100,
            "eta_min": 1e-6
        }
    },
    "trainer": {
        "epochs": 100,
        "save_dir": "saved/",
        "save_period": 1,
        "verbosity": 2,

        "monitor": "max val_accuracy",
        "early_stop": 15,

        "tensorboard": true
    }
}
