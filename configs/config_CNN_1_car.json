{
    "name": "CNN_1_car",
    "n_gpu": 1,
    "arch": {
        "type": "model_CNN_1",
        "args": {}
    },
    "data_loader": {
        "type": "Car_Hacking_DataLoader",
        "args": {
            "data_dir": "data/Car_hacking_split",
            "batch_size": 128,
            "shuffle": true,
            "num_workers": 0
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.001,
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": "nll_loss",
    "metrics": [
        "accuracy",
        "top_k_acc"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 50,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 100,
        "save_dir": "saved/",
        "save_period": 1,
        "verbosity": 2,
        "monitor": "min val_loss",
        "early_stop": 5,
        "tensorboard": true
    }
}